# Seller Central live execution config
# This template is for PRE-SUBMIT dry runs only.

# Enable the adapter
SELLER_CENTRAL_ADAPTER_ENABLED=true

# Safety guard: must remain true for pre-submit certification runs
SELLER_CENTRAL_DRY_RUN_PRE_SUBMIT=true

# Target Seller Central reimbursement/support flow URL
SELLER_CENTRAL_CASE_URL=https://sellercentral.amazon.com/help/hub/support

# Session/auth source
# Use ONE of the following:
# 1) Session file exported from a logged-in browser
SELLER_CENTRAL_SESSION_PATH=C:\\secure\\seller-central\\session.json
# 2) Raw cookies JSON instead of a session file
# SELLER_CENTRAL_COOKIES_JSON=[{"name":"session-id","value":"...","domain":".amazon.com","path":"/"}]

# Selector config
# Use one structured map OR the individual selector variables below.
SELLER_CENTRAL_SELECTOR_MAP={"subject":"textarea[name='subject']","body":"textarea[name='description']","attachmentInput":"input[type='file']","continueButtons":["button[data-testid='continue']"],"submit":"button[type='submit']","confirmation":"[data-testid='case-confirmation']","externalCaseId":"[data-testid='case-id']","authCheck":"nav[aria-label='Seller Central']","orderId":"input[name='orderId']","shipmentId":"input[name='shipmentId']","asin":"input[name='asin']","sku":"input[name='sku']","quantity":"input[name='quantity']","amountClaimed":"input[name='amount']","claimType":"select[name='claimType']"}

# Optional: use individual selector variables instead of SELLER_CENTRAL_SELECTOR_MAP
# SELLER_CENTRAL_SUBJECT_SELECTOR=textarea[name='subject']
# SELLER_CENTRAL_BODY_SELECTOR=textarea[name='description']
# SELLER_CENTRAL_ATTACHMENT_SELECTOR=input[type='file']
# SELLER_CENTRAL_CONTINUE_SELECTORS=["button[data-testid='continue']"]
# SELLER_CENTRAL_SUBMIT_SELECTOR=button[type='submit']
# SELLER_CENTRAL_CONFIRMATION_SELECTOR=[data-testid='case-confirmation']
# SELLER_CENTRAL_CASE_ID_SELECTOR=[data-testid='case-id']
# SELLER_CENTRAL_AUTH_CHECK_SELECTOR=nav[aria-label='Seller Central']
# SELLER_CENTRAL_ORDER_ID_SELECTOR=input[name='orderId']
# SELLER_CENTRAL_SHIPMENT_ID_SELECTOR=input[name='shipmentId']
# SELLER_CENTRAL_ASIN_SELECTOR=input[name='asin']
# SELLER_CENTRAL_SKU_SELECTOR=input[name='sku']
# SELLER_CENTRAL_QUANTITY_SELECTOR=input[name='quantity']
# SELLER_CENTRAL_AMOUNT_SELECTOR=input[name='amount']
# SELLER_CENTRAL_CLAIM_TYPE_SELECTOR=select[name='claimType']

# Optional runtime controls
SELLER_CENTRAL_HEADFUL=false
SELLER_CENTRAL_NAVIGATION_TIMEOUT_MS=60000
SELLER_CENTRAL_CONFIRM_TIMEOUT_MS=30000
SELLER_CENTRAL_TRACE_DIR=C:\\secure\\seller-central\\traces
